<?xml version="1.0" encoding="UTF-8"?>

<odoo>

    <record id="clinic_tree_view" model="ir.ui.view">
        <field name="name">hospital.clinic.tree</field>
        <field name="model">hospital.clinic</field>
        <field name="arch" type="xml">

            <list>

                <field name="name"/>
                <field name="open_datetime"/>
                <field name="end_datetime"/>
                <field name="description"/>

            </list>

        </field>
    </record>

    <record id="clinic_form_view" model="ir.ui.view">
        <field name="name">hospital.clinic.form</field>
        <field name="model">hospital.clinic</field>
        <field name="arch" type="xml">

            <form>

                <sheet>

                    <group>

                        <field name="name"/>
                        <field name="open_datetime"/>
                        <field name="end_datetime"/>
                        <field name="description"/>

                    </group>

                </sheet>

            </form>

        </field>
    </record>

    <record id="clinic_action" model="ir.actions.act_window">

        <field name="name">Clinics</field>

        <field name="res_model">hospital.clinic</field>

        <field name="view_mode">list,form</field>

    </record>

    <menuitem
        id="hospital_root_menu"
        name="Hospital"
    />

    <menuitem
        id="clinic_menu"
        name="Clinics"
        parent="hospital_root_menu"
        action="clinic_action"
    />

</odoo>